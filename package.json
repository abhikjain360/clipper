{
  "name": "clipper-workspace",
  "private": true,
  "scripts": {
    "check": "tsgo --noEmit -p tsconfig.json && pnpm -r run check",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "mobile:android": "pnpm --dir mobile run android",
    "mobile:check": "pnpm --dir packages/mobile-bridge run check && pnpm --dir mobile run check",
    "mobile:start": "pnpm --dir mobile run start",
    "mobile:uniffi:android": "pnpm --dir packages/mobile-bridge run ubrn:android",
    "web:build": "pnpm --dir web run build",
    "web:check": "pnpm --dir web run check",
    "web:dev": "pnpm --dir web run dev",
    "web:tauri:build": "pnpm --dir web run tauri:build",
    "web:tauri:dev": "pnpm --dir web run tauri:dev"
  },
  "devDependencies": {
    "@types/deno": "^2.7.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.4.0"
}
