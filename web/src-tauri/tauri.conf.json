{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Clipper",
    "version": "0.1.0",
    "identifier": "com.clipper.desktop",
    "build": {
        "beforeDevCommand": "pnpm run dev",
        "devUrl": "http://127.0.0.1:53880",
        "beforeBuildCommand": "pnpm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Clipper",
                "width": 1100,
                "height": 760,
                "minWidth": 720,
                "minHeight": 520
            }
        ],
        "security": {
            "capabilities": ["default"],
            "csp": {
                "default-src": ["'self'"],
                "script-src": ["'self'"],
                "style-src": ["'self'", "'unsafe-inline'"],
                "img-src": ["'self'", "data:", "blob:"],
                "font-src": ["'self'", "data:"],
                "connect-src": ["'self'", "ipc:", "http://ipc.localhost"],
                "object-src": ["'none'"],
                "base-uri": ["'none'"],
                "frame-src": ["'none'"],
                "frame-ancestors": ["'none'"],
                "form-action": ["'none'"],
                "worker-src": ["'none'"]
            },
            "devCsp": {
                "default-src": ["'self'"],
                "script-src": ["'self'", "'unsafe-eval'"],
                "style-src": ["'self'", "'unsafe-inline'"],
                "img-src": ["'self'", "data:", "blob:"],
                "font-src": ["'self'", "data:"],
                "connect-src": [
                    "'self'",
                    "ipc:",
                    "http://ipc.localhost",
                    "http://127.0.0.1:*",
                    "ws://127.0.0.1:*"
                ],
                "object-src": ["'none'"],
                "base-uri": ["'none'"],
                "frame-src": ["'none'"],
                "frame-ancestors": ["'none'"],
                "form-action": ["'none'"],
                "worker-src": ["'none'"]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "icon": [
            "icons/icon.icns",
            "icons/app_icon_32.png",
            "icons/app_icon_128.png",
            "icons/app_icon_256.png",
            "icons/app_icon_512.png",
            "icons/app_icon_1024.png"
        ]
    }
}
