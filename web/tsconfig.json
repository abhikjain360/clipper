{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "lib": ["DOM", "DOM.Iterable", "ES2024"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "noUncheckedIndexedAccess": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2024",
        "types": ["vite/client"]
    },
    "include": ["src", "vite.config.ts", "../packages/shared/src"]
}
