platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  # Add a build phase to the Runner target to build and embed clipper-daemon
  main_project = installer.aggregate_targets.first.user_project
  runner_target = main_project.targets.find { |t| t.name == 'Runner' }
  if runner_target
    phase_name = 'Build & Embed clipper-daemon'
    # Remove existing phase if present (idempotent)
    runner_target.shell_script_build_phases.each do |phase|
      if phase.name == phase_name
        runner_target.build_phases.delete(phase)
      end
    end
    phase = runner_target.new_shell_script_build_phase(phase_name)
    phase.output_paths = ['$(BUILT_PRODUCTS_DIR)/$(PRODUCT_NAME).app/Contents/MacOS/clipper-daemon']
    phase.shell_script = <<~SCRIPT
      set -e
      WORKSPACE_ROOT="$SRCROOT/../.."

      # Determine cargo profile from Xcode configuration
      if [ "$CONFIGURATION" = "Release" ] || [ "$CONFIGURATION" = "Profile" ]; then
        CARGO_PROFILE="release"
        CARGO_FLAGS="--release"
      else
        CARGO_PROFILE="debug"
        CARGO_FLAGS=""
      fi

      # Build clipper-daemon
      export PATH="$HOME/.cargo/bin:$PATH"
      cargo build -p clipper-daemon $CARGO_FLAGS --manifest-path "$WORKSPACE_ROOT/Cargo.toml"

      # Copy daemon binary into app bundle
      DAEMON_SRC="$WORKSPACE_ROOT/target/$CARGO_PROFILE/clipper-daemon"
      DAEMON_DST="$BUILT_PRODUCTS_DIR/$PRODUCT_NAME.app/Contents/MacOS/clipper-daemon"
      cp "$DAEMON_SRC" "$DAEMON_DST"
    SCRIPT
    main_project.save
  end
end
