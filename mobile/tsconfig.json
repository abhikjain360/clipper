{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["react"]
  },
  "include": ["index.ts", "src", "../packages/shared/src", "../packages/mobile-bridge/src"]
}
